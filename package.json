{
  "name": "bm-player",
  "productName": "BM Player",
  "version": "1.4.3",
  "description": "A professional media player powered by mpv",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build:win64": "npm run gen-icon && electron-builder --win --x64",
    "build:win32": "npm run gen-icon && electron-builder --win --ia32",
    "gen-icon": "node scripts/generate-icon.js"
  },
  "author": "BM Player",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BritMat/bm-player.git"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "electron-updater": "^6.1.7",
    "jimp": "^1.6.1",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1"
  }
}
